{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sublist3r4m Configuration",
  "description": "Schema for validating the Sublist3r4m config.json file.",
  "type": "object",
  "properties": {
    "api_keys": {
      "type": "object",
      "description": "API key configurations for external services.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "api_key": {
            "type": "string",
            "description": "Primary API key for the service."
          },
          "api_id": {
            "type": "string",
            "description": "API identifier (used by services like Censys)."
          },
          "api_secret": {
            "type": "string",
            "description": "API secret (used by services like Censys)."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this API source is enabled."
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the service."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to obtain or manage the API key."
          }
        },
        "required": ["enabled"],
        "additionalProperties": false
      }
    },
    "endpoints": {
      "type": "object",
      "description": "Endpoint configurations for data sources.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "cdx_api": {
            "type": "string",
            "format": "uri",
            "description": "CDX API URL (Wayback Machine)."
          },
          "api_url": {
            "type": "string",
            "format": "uri",
            "description": "API URL for the endpoint."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this endpoint is enabled."
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the endpoint."
          }
        },
        "required": ["enabled"],
        "additionalProperties": false
      }
    },
    "settings": {
      "type": "object",
      "description": "General runtime settings.",
      "properties": {
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300,
          "description": "HTTP request timeout in seconds."
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "description": "Maximum number of retries per request."
        },
        "delay_between_requests": {
          "type": "number",
          "minimum": 0,
          "description": "Delay in seconds between consecutive requests."
        },
        "user_agent": {
          "type": "string",
          "minLength": 1,
          "description": "User-Agent header sent with HTTP requests."
        },
        "max_subdomains_per_source": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum subdomains to collect from a single source."
        },
        "enable_dns_resolution": {
          "type": "boolean",
          "description": "Whether to resolve discovered subdomains via DNS."
        },
        "enable_ip_collection": {
          "type": "boolean",
          "description": "Whether to collect IP addresses for resolved subdomains."
        },
        "verbose_logging": {
          "type": "boolean",
          "description": "Enable verbose log output."
        }
      },
      "additionalProperties": false
    },
    "wordlists": {
      "type": "object",
      "description": "Wordlist paths for brute-force and directory scanning.",
      "properties": {
        "dns_bruteforce": {
          "type": "object",
          "description": "Wordlists for DNS subdomain brute-forcing.",
          "properties": {
            "default": {
              "type": "string",
              "description": "Path to the default wordlist."
            },
            "large": {
              "type": "string",
              "description": "Path to a larger wordlist."
            },
            "custom": {
              "type": "string",
              "description": "Path to a custom wordlist (empty string if unused)."
            }
          },
          "additionalProperties": false
        },
        "directories": {
          "type": "object",
          "description": "Wordlists for directory scanning.",
          "properties": {
            "common": {
              "type": "string",
              "description": "Path to the common directories wordlist."
            },
            "custom": {
              "type": "string",
              "description": "Path to a custom directories wordlist (empty string if unused)."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["api_keys", "endpoints", "settings"],
  "additionalProperties": false
}
