{
  "api_keys": {
    "shodan": {
      "api_key": "",
      "enabled": false,
      "description": "Shodan API for infrastructure discovery",
      "url": "https://account.shodan.io/"
    },
    "censys": {
      "api_id": "",
      "api_secret": "",
      "enabled": false,
      "description": "Censys API for internet-wide scanning",
      "url": "https://censys.io/register"
    },
    "securitytrails": {
      "api_key": "",
      "enabled": false,
      "description": "SecurityTrails API for passive DNS",
      "url": "https://securitytrails.com/"
    },
    "virustotal": {
      "api_key": "",
      "enabled": false,
      "description": "VirusTotal API for domain analysis",
      "url": "https://www.virustotal.com/gui/join-us"
    },
    "threatcrowd": {
      "enabled": true,
      "description": "ThreatCrowd public API (no key required)",
      "url": "https://threatcrowd.org/"
    },
    "passivedns": {
      "api_key": "",
      "enabled": false,
      "description": "PassiveTotal/RiskIQ API",
      "url": "https://community.riskiq.com/"
    }
  },
  "endpoints": {
    "wayback_machine": {
      "cdx_api": "https://web.archive.org/cdx/search/cdx",
      "enabled": true,
      "description": "Wayback Machine CDX API (free)"
    },
    "crt_sh": {
      "api_url": "https://crt.sh/",
      "enabled": true,
      "description": "Certificate Transparency logs"
    },
    "threatcrowd": {
      "api_url": "https://threatcrowd.org/searchApi/v2/domain/report/",
      "enabled": true,
      "description": "ThreatCrowd domain intelligence"
    }
  },
  "settings": {
    "timeout": 30,
    "max_retries": 3,
    "delay_between_requests": 1,
    "user_agent": "JARVIS Intelligence Scanner v1.0",
    "max_subdomains_per_source": 1000,
    "enable_dns_resolution": true,
    "enable_ip_collection": true,
    "verbose_logging": false
  },
  "wordlists": {
    "dns_bruteforce": {
      "default": "subbrute/names.txt",
      "large": "wordlists/all.txt",
      "custom": ""
    },
    "directories": {
      "common": "wordlists/common_dirs.txt",
      "custom": ""
    }
  }
}
