{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "JARVIS Intelligence - Debug Mode",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/jarvis_intelligence.py",
            "args": ["-d", "microsoft.com", "--debug"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "JARVIS Intelligence - Complete Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/jarvis_intelligence.py",
            "args": ["-d", "thales.com", "--preset", "complete", "--intelligence", "--ai-export", "intelligence_report.json"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Sublist3r Original - Debug Mode", 
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sublist3r.py",
            "args": ["-d", "example.com", "-v"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Owner Research Engine - Test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/owner_research_engine.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}